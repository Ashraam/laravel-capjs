{
  "name": "ashraam/laravel-capjs",
  "description": "A simple package to integrate Cap.js, an hCaptcha-like open source challenge, into your Laravel application.",
  "keywords": [
    "ashraam",
    "capjs",
    "laravel",
    "captcha",
    "hcaptcha",
    "cap.js"
  ],
  "homepage": "https://github.com/ashraam/laravel-capjs",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Romain BERTOLUCCI",
      "email": "romain.bertolucci@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0|^11.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Ashraam\\Capjs\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ashraam\\Capjs\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ashraam\\Capjs\\CapjsServiceProvider"
      ],
      "aliases": {
        "Capjs": "Ashraam\\Capjs\\CapjsFacade"
      }
    }
  }
}
