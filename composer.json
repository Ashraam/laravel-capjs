{
  "name": "ashraam/laravel-capjs",
  "description": "",
  "keywords": [
    "ashraam",
    "capjs"
  ],
  "homepage": "https://github.com/ashraam/laravel-capjs",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Romain BERTOLUCCI",
      "email": "romain.bertolucci@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^7.4|^8.0",
    "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0",
    "illuminate/http": "^8.0|^9.0|^10.0|^11.0|^12.0",
    "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^6.0",
    "phpunit/phpunit": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "Ashraam\\Capjs\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ashraam\\Capjs\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ashraam\\Capjs\\CapjsServiceProvider"
      ],
      "aliases": {
        "Capjs": "Ashraam\\Capjs\\CapjsFacade"
      }
    }
  }
}
